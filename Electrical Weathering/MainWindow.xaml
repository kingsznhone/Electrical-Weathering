<ui:FluentWindow x:Name="_this" x:Class="Electrical_Weathering.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:Behaviors="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 Title="{Binding ApplicationTitle}"
                 d:DesignWidth="960" d:DesignHeight="540"
                 MinWidth="960" MinHeight="540"
                 Icon="Weathering.bmp"
                 WindowStartupLocation="CenterScreen"
                 AllowDrop="True"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Closed="Window_Closed"
                 Drop="FilePath_Drop">

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" x:Name="TitleBar"  Title="{Binding ApplicationTitle}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Weathering.bmp" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="24,0,24,24">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="480" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,0,0" >
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="36"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Border x:Name="PreviewImageBorder"
                           Margin="0,0,0,12"
                           VerticalAlignment="Stretch"
                           Background="LightGray"
                           CornerRadius="8">
                            <Image x:Name="PreviewImage" Source="{Binding PreviewImage}"
                           Stretch="Uniform" StretchDirection="Both" Margin="12,12,12,12" AllowDrop="True" />
                        </Border>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Border x:Name="ImageInfoPanel"
                           Padding="14,7"
                           VerticalAlignment="Bottom"
                           BorderBrush="LightGray"
                           BorderThickness="2"
                           CornerRadius="8">
                            <ui:TextBlock x:Name="ImageInfoText" TextAlignment="Center" Text="{Binding ImageInfo}" />
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.Column="1" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: 文件选择 -->
                <Grid Grid.Row="0" Margin="16,0,0,0" >
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" Name="FilePathTextBox" Text="{Binding FilePath,Mode=TwoWay}" IsReadOnly="True"
                             VerticalAlignment="Center" Margin="0,0,8,0"
                             TextWrapping="NoWrap" TextAlignment="Left"
                             Cursor="IBeam" />
                        <ui:Button Grid.Column="1" x:Name="FileSelectBtn" Content="选择文件"
                            VerticalAlignment="Center" Width="80"
                             Command="{Binding SelectFileClickCommand}" />
                    </Grid>
                    
                </Grid>

                <!-- Row 1: 参数滑块 -->
                <Grid Grid.Row="1" Margin="16,12,0,0" >
                    <StackPanel VerticalAlignment="Top">
                        <ui:CardControl CornerRadius="8" Margin="0,0,0,8">
                            <ui:CardControl.Header>
                                <StackPanel Margin="0,0,12,0">
                                    <ui:TextBlock Margin="0"
                                               FontTypography="BodyStrong"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Text="绿化迭代"
                                               TextWrapping="WrapWithOverflow" />
                                    <ui:TextBlock 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="每 1% 代表一次 SKIA 色偏迭代，最高 200 次"
                                               TextWrapping="WrapWithOverflow" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <Grid Width="238" Margin="16,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>
                                <Slider Name="Slider_Greening" Value="{Binding Green}"
                                     Grid.Column="0"
                                     VerticalAlignment="Center"
                                     Maximum="1" TickFrequency="0.01" SmallChange="0.01" LargeChange="0.01"
                                     IsSnapToTickEnabled="True">
                                    <Behaviors:Interaction.Triggers>
                                        <Behaviors:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                            <Behaviors:InvokeCommandAction Command="{Binding SliderMouseUpCommand}" />
                                        </Behaviors:EventTrigger>
                                    </Behaviors:Interaction.Triggers>
                                </Slider>
                                <TextBlock Name="TextGreeningValue"
                                        Grid.Column="1"
                                        Text="{Binding Green,StringFormat={}{0:P0}}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right" />
                            </Grid>
                        </ui:CardControl>

                        <ui:CardControl CornerRadius="8" Margin="0,0,0,8">
                            <ui:CardControl.Header>
                                <StackPanel Margin="0,0,12,0">
                                    <ui:TextBlock Margin="0"
                                               FontTypography="BodyStrong"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Text="压缩损耗"
                                               TextWrapping="WrapWithOverflow" />
                                    <ui:TextBlock
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="越高越像多次低质 JPEG 转存"
                                               TextWrapping="WrapWithOverflow" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <Grid Width="238" Margin="16,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>
                                <Slider Name="Slider_Compressing" Value="{Binding Compressing}"
                                     Grid.Column="0"
                                     VerticalAlignment="Center"
                                     Maximum="1" TickFrequency="0.01" SmallChange="0.01" LargeChange="0.01"
                                     IsSnapToTickEnabled="True">
                                    <Behaviors:Interaction.Triggers>
                                        <Behaviors:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                            <Behaviors:InvokeCommandAction Command="{Binding SliderMouseUpCommand}" />
                                        </Behaviors:EventTrigger>
                                    </Behaviors:Interaction.Triggers>
                                </Slider>
                                <TextBlock Name="TextCompressingValue"
                                        Grid.Column="1"
                                        Text="{Binding Compressing,StringFormat={}{0:P0}}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right" />
                            </Grid>
                        </ui:CardControl>

                        <ui:CardControl CornerRadius="8">
                            <ui:CardControl.Header>
                                <StackPanel Margin="0,0,12,0">
                                    <ui:TextBlock Margin="0"
                                               FontTypography="BodyStrong"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Text="尺寸缩放"
                                               TextWrapping="WrapWithOverflow" />
                                    <ui:TextBlock 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="缩放后进入迭代，比例越低越糊"
                                               TextWrapping="WrapWithOverflow" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <Grid Width="238" Margin="16,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>
                                <Slider Name="Slider_Scaling" Value="{Binding Scaling}"
                                     Grid.Column="0"
                                     VerticalAlignment="Center"
                                     Minimum="0.01" Maximum="1" TickFrequency="0.01" SmallChange="0.01" LargeChange="0.01"
                                     IsSnapToTickEnabled="True">
                                    <Behaviors:Interaction.Triggers>
                                        <Behaviors:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                            <Behaviors:InvokeCommandAction Command="{Binding SliderMouseUpCommand}" />
                                        </Behaviors:EventTrigger>
                                    </Behaviors:Interaction.Triggers>
                                </Slider>
                                <TextBlock x:Name="TextScalingValue"
                                        Grid.Column="1"
                                        Text="{Binding Scaling,StringFormat={}{0:P0}}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right" />
                            </Grid>
                        </ui:CardControl>
                    </StackPanel>
                </Grid>

                <!-- Row 2: 预设选择 -->
                <Grid Grid.Row="2" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                        <RadioButton x:Name="RB_Low" Content="元青花"  IsChecked="{Binding Low_Checked}" GroupName="WeatheringDefault" Command="{Binding PresetLowClickCommand}" />
                        <RadioButton x:Name="RB_Medium" Content="唐三彩"  IsChecked="{Binding Medium_Checked}" GroupName="WeatheringDefault" Command="{Binding PresetMediumClickCommand}" />
                        <RadioButton x:Name="RB_High" Content="兵马俑"  IsChecked="{Binding High_Checked}" GroupName="WeatheringDefault" Command="{Binding PresetHighClickCommand}" />
                        <RadioButton x:Name="RB_Custom" Content="自定义" IsChecked="{Binding Custom_Checked}" GroupName="WeatheringDefault" />
                    </StackPanel>
                </Grid>

                <!-- Row 4: 操作按钮 -->
                <Grid Grid.Row="3" Margin="16,12,0,0" >
                    <ui:Button x:Name="Btn_Revert" Content="重置" Appearance="Secondary"
                         HorizontalAlignment="Left" Width="80"
                         Command="{Binding ResetClickCommand}" />
                    <ui:Button x:Name="Btn_Save" Content="保存" Appearance="Primary"
                         HorizontalAlignment="Right" Width="80"
                         Command="{Binding SaveClickCommand}" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>

</ui:FluentWindow>
